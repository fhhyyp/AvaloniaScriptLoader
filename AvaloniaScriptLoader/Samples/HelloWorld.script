// Hello World — 最简单的脚本 UI 示例
import { app } from "avalonia"
import { window, label } from "avalonia.controls"

window({
    "title" = "Hello Avalonia Script",
    "width" = 400,
    "height" = 200,
    "content" = label({
        "text" = "你好，脚本语言 UI 框架！",
        "fontSize" = 20,
        "align" = "center"
    })
})
